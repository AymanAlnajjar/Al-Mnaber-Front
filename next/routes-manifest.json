      "page": "/careers/[id]",
      "regex": "^/careers/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/careers/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/services/[id]",
